{
  "name": "workflow-manager",
  "version": "1.0.0",
  "description": "Workflow Manager - A personal workflow execution tool",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.workflow.manager",
    "productName": "Workflow Manager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "src/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": null
    }
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2",
    "electron-rebuild": "^3.2.9"
  },
  "dependencies": {
    "@editorjs/editorjs": "^2.31.6",
    "@editorjs/header": "^2.8.9",
    "@editorjs/image": "^2.10.3",
    "@editorjs/list": "^2.0.9",
    "@editorjs/paragraph": "^2.11.7",
    "@editorjs/underline": "^1.2.1",
    "better-sqlite3": "^9.4.3"
  }
}
